# ── Cloudflare R2 Image Storage ──────────────────────────────────────────────
# Server-side (used by Express server only, never expose to the client)

# Your Cloudflare account ID (visible in the Cloudflare dashboard)
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 API token credentials (create at Cloudflare → R2 → Manage R2 API Tokens)
# Permissions: Object Read & Write
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 bucket name (default: survey-images)
R2_BUCKET_NAME=survey-images

# Public base URL for the R2 bucket.
# Options:
#   1. R2.dev subdomain (free):  https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
#   2. Custom domain (recommended): https://images.yourdomain.com
# No trailing slash.
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ── Client-side React (prefix REACT_APP_) ────────────────────────────────────
# Set to the same value as R2_PUBLIC_URL so the React app knows R2 is enabled.
REACT_APP_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Optional: override the Express server URL used by the React frontend
# Defaults to http://localhost:3001 in development, '' (same origin) in production
# REACT_APP_SERVER_URL=http://localhost:3001

# ── Supabase (database / auth only – image storage is now on R2) ──────────────
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only (Express / Cloudflare Worker). Required for guest
# "Request a Template for Your Paper" submissions (bypasses templates RLS).
# Never expose this key to the React client. On Cloudflare, set via:
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#   wrangler secret put SUPABASE_URL   (or set SUPABASE_URL / REACT_APP_SUPABASE_URL in vars)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI Assistant / Agent / MCP ────────────────────────────────────────────────
# Users store their own OpenAI (sk-...) or OpenRouter (sk-or-...) key via
# AI & Integrations. Keys are encrypted with BYOK_ENCRYPTION_KEY (Worker secret).
#
# Required Cloudflare Worker Secrets (survive deploys):
#   wrangler secret put BYOK_ENCRYPTION_KEY
#   wrangler secret put SUPABASE_ANON_KEY
#   wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#
# Plaintext APP_URL / MCP_RESOURCE / SUPABASE_URL live in wrangler.jsonc.
# Dashboard plaintext vars are wiped on every `wrangler deploy`.
# BYOK_ENCRYPTION_KEY_ID=1
#
# Client-side public site URL for Codex MCP setup prompts on Integrations.
# Defaults to https://sp-survey.org when the admin UI is opened on localhost.
# REACT_APP_APP_URL=https://sp-survey.org
#
# Local Express parity uses the same vars from this .env file.
# REACT_APP_SERVER_URL=http://localhost:3001
# (REACT_APP_API_URL is deprecated; prefer REACT_APP_SERVER_URL)
