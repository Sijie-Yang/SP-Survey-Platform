{
  "id": "2026-sp-bench-expert",
  "name": "SP-Bench Expert Labeling Protocol",
  "description": "Human-expert questionnaire aligned with SP-Bench v1 dimensions (objective / subjective / cognition), plus extended perception scales and pairwise preference. Upload the SP-Bench image set to Media Dataset before running. Field names match SP-Bench keys for export and gold-label construction.",
  "author": "Urban Analytics Lab / SP-Bench",
  "year": "2026",
  "category": "Academic Research",
  "tags": [
    "official",
    "sp-bench",
    "expert",
    "labeling",
    "benchmark"
  ],
  "isPinned": true,
  "website": "https://sp-survey.org/bench",
  "huggingfaceDataset": null,
  "createdAt": "2026-07-22T00:00:00.000+00:00",
  "config": {
    "title": "SP-Bench — Human Expert Streetscape Labeling",
    "description": "Expert annotation protocol for SP-Bench: Subjective–Objective Spatial Perception and Cognition in Urban Environments.",
    "logo": "",
    "logoPosition": "right",
    "showQuestionNumbers": "on",
    "showProgressBar": "aboveheader",
    "progressBarType": "questions",
    "autoGrowComment": true,
    "pages": [
      {
        "name": "intro",
        "title": "1. Introduction & consent",
        "description": "This protocol produces human gold labels for SP-Bench model evaluation. Judge each streetscape carefully and consistently.",
        "elements": [
          {
            "name": "intro_text",
            "type": "expression",
            "title": "About this study",
            "description": "You will label street-view scenes on (A) objective visual properties, (B) subjective perception, and (C) cognitive cues (risk / affordances). Optional pairwise comparisons follow."
          },
          {
            "name": "consent",
            "type": "consent",
            "title": "I understand the task and agree to provide careful expert judgments for research use.",
            "labelTrue": "I agree",
            "labelFalse": "I do not agree",
            "isRequired": true
          },
          {
            "name": "expert_role",
            "type": "checkbox",
            "title": "Your expertise (select all that apply)",
            "isRequired": true,
            "choices": [
              { "value": "urban_planning", "text": "Urban planning / design" },
              { "value": "architecture", "text": "Architecture" },
              { "value": "geography_gis", "text": "Geography / GIS / remote sensing" },
              { "value": "transport", "text": "Transport / walkability" },
              { "value": "env_psych", "text": "Environmental psychology / perception" },
              { "value": "cv_ml", "text": "Computer vision / ML for cities" },
              { "value": "other", "text": "Other related field" }
            ]
          },
          {
            "name": "expert_experience_years",
            "type": "dropdown",
            "title": "Years of relevant experience",
            "isRequired": false,
            "choices": [
              { "value": "0-2", "text": "0–2 years" },
              { "value": "3-5", "text": "3–5 years" },
              { "value": "6-10", "text": "6–10 years" },
              { "value": "10plus", "text": "More than 10 years" }
            ]
          },
          {
            "name": "labeling_notes",
            "type": "expression",
            "title": "How to label",
            "description": "1) Upload the SP-Bench image set into this project’s Media Dataset.\n2) Each image block runs multiple trials (one scene per trial).\n3) Keep criteria stable across scenes.\n4) For gold labels, prefer a curated/fixed image order so trial i maps to the same filename across blocks when you post-process exports.\n5) Ratio sliders use 0–100 (% of image → divide by 100 for SP-Bench). Likert / enclosure use 1–7."
          }
        ]
      },
      {
        "name": "objective_ratios",
        "title": "2. Objective — visual composition ratios",
        "description": "SP-Bench objective continuous keys: green_view_ratio, sky_ratio (+ extended building_ratio).",
        "elements": [
          {
            "name": "sp_bench_ratios",
            "type": "imageslidergroup",
            "title": "Visual composition ratios (0–100%)",
            "description": "Estimate the share of the image occupied by each class. Export to SP-Bench as value/100.",
            "imageCount": 1,
            "trialCount": 15,
            "isRequired": true,
            "scaleMin": 0,
            "scaleMax": 100,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false,
            "dimensions": [
              {
                "id": "green_view_ratio",
                "left": "0% green",
                "right": "100% green"
              },
              {
                "id": "sky_ratio",
                "left": "0% sky",
                "right": "100% sky"
              },
              {
                "id": "building_ratio",
                "left": "0% building",
                "right": "100% building"
              }
            ]
          }
        ]
      },
      {
        "name": "subjective_likert",
        "title": "3. Objective enclosure & subjective perception (1–7)",
        "description": "SP-Bench keys: enclosure, safety, beauty, vitality, walkability. Extended: comfort, orderliness, interestingness.",
        "elements": [
          {
            "name": "sp_bench_likert",
            "type": "imageslidergroup",
            "title": "Enclosure & perception (1–7)",
            "description": "1 = very low / negative pole · 7 = very high / positive pole.",
            "imageCount": 1,
            "trialCount": 15,
            "isRequired": true,
            "scaleMin": 1,
            "scaleMax": 7,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false,
            "dimensions": [
              {
                "id": "enclosure",
                "left": "Very open",
                "right": "Very enclosed"
              },
              {
                "id": "safety",
                "left": "Very unsafe",
                "right": "Very safe"
              },
              {
                "id": "beauty",
                "left": "Very ugly",
                "right": "Very beautiful"
              },
              {
                "id": "vitality",
                "left": "Very lifeless",
                "right": "Very lively"
              },
              {
                "id": "walkability",
                "left": "Very unwalkable",
                "right": "Very walkable"
              },
              {
                "id": "comfort",
                "left": "Very uncomfortable",
                "right": "Very comfortable"
              },
              {
                "id": "orderliness",
                "left": "Very chaotic",
                "right": "Very orderly"
              },
              {
                "id": "interestingness",
                "left": "Very boring",
                "right": "Very interesting"
              }
            ]
          }
        ]
      },
      {
        "name": "scene_type",
        "title": "4. Scene / street type",
        "description": "SP-Bench key: scene_type. Select the single best matching category.",
        "elements": [
          {
            "name": "sp_bench_scene_type",
            "type": "imagecheckbox",
            "title": "Scene / street type",
            "description": "Select exactly ONE category that best describes this scene.",
            "imageCount": 1,
            "trialCount": 15,
            "isRequired": true,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false,
            "choices": [
              { "value": "residential", "text": "Residential" },
              { "value": "commercial", "text": "Commercial" },
              { "value": "mixed", "text": "Mixed-use" },
              { "value": "park", "text": "Park / open green" },
              { "value": "highway", "text": "Highway / arterial" },
              { "value": "alley", "text": "Alley / laneway" },
              { "value": "waterfront", "text": "Waterfront" }
            ]
          }
        ]
      },
      {
        "name": "cognition",
        "title": "5. Cognitive cues",
        "description": "SP-Bench cognition group: risk_cues and affordances (multi-label).",
        "elements": [
          {
            "name": "sp_bench_risk_cues",
            "type": "imagecheckbox",
            "title": "Risk cues",
            "description": "Select all risks that are visually suggested. Choose “none” only if no notable risk cue is present.",
            "imageCount": 1,
            "trialCount": 15,
            "isRequired": true,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false,
            "choices": [
              { "value": "traffic", "text": "Traffic hazard" },
              { "value": "crime", "text": "Crime / social disorder cue" },
              { "value": "darkness", "text": "Darkness / poor lighting" },
              { "value": "construction", "text": "Construction / temporary hazard" },
              { "value": "flooding", "text": "Flooding / water hazard" },
              { "value": "none", "text": "None of the above" }
            ]
          },
          {
            "name": "sp_bench_affordances",
            "type": "imagecheckbox",
            "title": "Affordances",
            "description": "Select all activities this streetscape clearly affords.",
            "imageCount": 1,
            "trialCount": 15,
            "isRequired": true,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false,
            "choices": [
              { "value": "walk", "text": "Walk" },
              { "value": "sit", "text": "Sit / linger" },
              { "value": "cycle", "text": "Cycle" },
              { "value": "cross", "text": "Cross the street" },
              { "value": "socialize", "text": "Socialize" },
              { "value": "exercise", "text": "Exercise / active recreation" }
            ]
          }
        ]
      },
      {
        "name": "pairwise",
        "title": "6. Pairwise preference",
        "description": "Place-Pulse–style comparisons for preference modeling beyond absolute Likert scores.",
        "elements": [
          {
            "name": "sp_bench_pairwise_walk",
            "type": "imagepicker",
            "title": "Which place would you rather walk in?",
            "description": "Select the preferred scene.",
            "imageCount": 2,
            "trialCount": 10,
            "multiSelect": false,
            "isRequired": false,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false
          },
          {
            "name": "sp_bench_pairwise_beauty",
            "type": "imagepicker",
            "title": "Which place looks more beautiful?",
            "description": "Select the preferred scene.",
            "imageCount": 2,
            "trialCount": 10,
            "multiSelect": false,
            "isRequired": false,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false
          },
          {
            "name": "sp_bench_pairwise_safety",
            "type": "imagepicker",
            "title": "Which place looks safer?",
            "description": "Select the preferred scene.",
            "imageCount": 2,
            "trialCount": 10,
            "multiSelect": false,
            "isRequired": false,
            "imageSelectionMode": "huggingface_random",
            "randomImageSelection": true,
            "excludePreviouslyUsedImages": false
          }
        ]
      },
      {
        "name": "quality_debrief",
        "title": "7. Quality & debrief",
        "description": "Help us assess label reliability.",
        "elements": [
          {
            "name": "label_confidence",
            "type": "rating",
            "title": "Overall confidence in your labels for this session",
            "rateMin": 1,
            "rateMax": 7,
            "minRateDescription": "Very low",
            "maxRateDescription": "Very high",
            "isRequired": true
          },
          {
            "name": "difficult_cases",
            "type": "comment",
            "title": "Any scenes or dimensions that were particularly difficult?",
            "rows": 3,
            "isRequired": false
          },
          {
            "name": "protocol_feedback",
            "type": "comment",
            "title": "Suggestions to improve this expert protocol",
            "rows": 3,
            "isRequired": false
          }
        ]
      }
    ]
  }
}
