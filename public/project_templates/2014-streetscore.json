{
  "id": "2014-streetscore",
  "name": "Streetscore – Perceived Safety Rating",
  "description": "Single-image perceived safety rating survey. Participants rate street scenes on a 1–10 safety scale and provide contextual judgments. Based on the Streetscore methodology predicting perceived safety of urban streetscapes.",
  "author": "Naik et al.",
  "year": "2014",
  "category": "Reference Template",
  "tags": [
    "reference",
    "ai-generated"
  ],
  "website": "https://www.media.mit.edu/projects/streetscore/overview/",
  "createdAt": "2026-05-04T00:00:00.000Z",
  "config": {
    "title": "Streetscore – Perceived Safety Survey",
    "description": "Rate each street scene on how safe it feels. Based on: Naik, N., Philipoom, J., Raskar, R., & Hidalgo, C. (2014). Streetscore—Predicting the perceived safety of one million streetscapes. CVPR Workshops 2014.",
    "logoPosition": "right",
    "showQuestionNumbers": "off",
    "showProgressBar": "aboveheader",
    "progressBarType": "questions",
    "autoGrowComment": true,
    "showPreviewBeforeComplete": "showAllQuestions",
    "pages": [
      {
        "name": "page_intro",
        "title": "Instructions",
        "description": "In this survey, you will see a series of street-level photographs. For each image, please rate how safe the street looks on a scale from 1 (very unsafe) to 10 (very safe). There are no right or wrong answers — we are interested in your personal impression.",
        "elements": [
          {
            "type": "expression",
            "name": "safety_intro",
            "title": "How to respond",
            "description": "Use the 1–10 scale to rate perceived safety. Consider factors like lighting, visibility, human presence, and physical environment."
          }
        ]
      },
      {
        "name": "page_safety_1",
        "title": "Safety Rating",
        "description": "Look at the street scene below and rate its perceived safety.",
        "elements": [
          {
            "type": "image",
            "name": "street_image_1",
            "title": "Street Scene",
            "isRequired": false,
            "imageCount": 1,
            "imageSelectionMode": "huggingface_random",
            "imageFit": "cover",
            "randomImageSelection": true,
            "imageSource": "huggingface"
          },
          {
            "type": "rating",
            "name": "safety_score_1",
            "title": "How safe does this street look?",
            "isRequired": true,
            "rateMin": 1,
            "rateMax": 10,
            "minRateDescription": "Very unsafe",
            "maxRateDescription": "Very safe"
          },
          {
            "type": "radiogroup",
            "name": "safety_reason_1",
            "title": "What most influences your safety perception of this scene?",
            "isRequired": false,
            "choices": [
              {
                "value": "lighting",
                "text": "Lighting conditions"
              },
              {
                "value": "people",
                "text": "Presence / absence of people"
              },
              {
                "value": "maintenance",
                "text": "Building / street maintenance"
              },
              {
                "value": "greenery",
                "text": "Greenery and open space"
              },
              {
                "value": "traffic",
                "text": "Traffic and road design"
              },
              {
                "value": "other",
                "text": "Other"
